# ===========================================
# Frontend Configuration (Vite)
# ===========================================

# Show/hide floating debug button in editor (dev mode only)
# Set to 'false' to hide debug panel button during development
VITE_SHOW_DEBUG_PANEL=true

# ===========================================
# Feature Flags
# ===========================================
# Control which major features are available
# Set to 'false' to disable/hide a feature

VITE_FEATURE_MEDIA_LIBRARY=true
VITE_FEATURE_TIMELINE=true
VITE_FEATURE_EFFECTS=true
VITE_FEATURE_PLAYER=true
VITE_FEATURE_TEXT=false
VITE_FEATURE_SHAPES=false
VITE_FEATURE_TRANSITIONS=false
VITE_FEATURE_KEYFRAMES=false
VITE_FEATURE_EXPORT=false
VITE_FEATURE_SETTINGS=false
VITE_FEATURE_PROJECT_BUNDLE=false
VITE_FEATURE_COMPOSITION_RUNTIME=false

# ===========================================
# UI Components Feature Flags
# ===========================================
# Control individual UI components individually
# Set to 'false' to disable/hide a component

VITE_UI_ACCORDION=false
VITE_UI_ALERT_DIALOG=false
VITE_UI_ALERT=true
VITE_UI_BUTTON=true
VITE_UI_COLLAPSIBLE=false
VITE_UI_CONTEXT_MENU=false
VITE_UI_DIALOG=true
VITE_UI_DROPDOWN_MENU=true
VITE_UI_GLOBAL_TOOLTIP=false
VITE_UI_INPUT=true
VITE_UI_LABEL=true
VITE_UI_PROGRESS=false
VITE_UI_RESIZABLE=false
VITE_UI_SCROLL_AREA=true
VITE_UI_SELECT=true
VITE_UI_SEPARATOR=false
VITE_UI_SLIDER=false
VITE_UI_SONNER=false
VITE_UI_SWITCH=false
VITE_UI_TABS=true
VITE_UI_TEXTAREA=false
VITE_UI_TOOLTIP=true
